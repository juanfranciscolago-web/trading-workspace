# =============================================================================
# Trading Workspace — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` to git.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your real credentials
# =============================================================================

# -----------------------------------------------------------------------------
# Anthropic API (for ClaudeRouter)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# Database (PostgreSQL via docker-compose)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://trader:trader@localhost:5432/trading
DB_POOL_MIN=2
DB_POOL_MAX=10

# -----------------------------------------------------------------------------
# Redis (cache + pub/sub)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Schwab API (for both Eolo and multi-agent)
# -----------------------------------------------------------------------------
SCHWAB_API_KEY=
SCHWAB_API_SECRET=
SCHWAB_REFRESH_TOKEN=
SCHWAB_PAPER_TRADING=true   # IMPORTANT: keep `true` until system is validated

# -----------------------------------------------------------------------------
# Market Data Providers
# -----------------------------------------------------------------------------
POLYGON_API_KEY=
BENZINGA_API_KEY=
FRED_API_KEY=

# -----------------------------------------------------------------------------
# On-chain Data
# -----------------------------------------------------------------------------
GLASSNODE_API_KEY=
CRYPTOQUANT_API_KEY=

# -----------------------------------------------------------------------------
# ATLAS Risk Service
# -----------------------------------------------------------------------------
ATLAS_ENDPOINT=http://localhost:8001
ATLAS_FAIL_OPEN=false   # IMPORTANT: keep `false` (fail closed for safety)

# -----------------------------------------------------------------------------
# Notifications
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
# Crypto Exchange Keys (CCXT)
# -----------------------------------------------------------------------------
BINANCE_API_KEY=
BINANCE_API_SECRET=
COINBASE_API_KEY=
COINBASE_API_SECRET=
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO   # DEBUG, INFO, WARNING, ERROR

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
ENVIRONMENT=development   # development, staging, production

# -----------------------------------------------------------------------------
# Multi-Agent System Specific
# -----------------------------------------------------------------------------
# ClaudeRouter config path
CLAUDE_ROUTER_CONFIG=multi-agent-system/claude_router/config/routing_rules.yaml

# Maximum daily LLM cost before alerting (USD)
LLM_DAILY_COST_ALERT=50

# Maximum monthly LLM cost before alerting (USD)
LLM_MONTHLY_COST_ALERT=200
