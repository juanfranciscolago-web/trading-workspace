# =============================================================================
# Trading Workspace — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` to git.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your real credentials
# =============================================================================

# -----------------------------------------------------------------------------
# Anthropic API (for ClaudeRouter)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# Database (PostgreSQL via docker-compose)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://trader:trader@localhost:5432/trading
DB_POOL_MIN=2
DB_POOL_MAX=10

# -----------------------------------------------------------------------------
# Redis (cache + pub/sub)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Schwab API (for both Eolo and multi-agent)
# -----------------------------------------------------------------------------
SCHWAB_API_KEY=
SCHWAB_API_SECRET=
SCHWAB_REFRESH_TOKEN=
SCHWAB_PAPER_TRADING=true   # IMPORTANT: keep `true` until system is validated

# -----------------------------------------------------------------------------
# Multi-agent ATLAS (Sprint 11+ live mode)
# -----------------------------------------------------------------------------
# Sprint 11 atlas-d added Settings (ADR-013 D9 + D10), template gap catched
# Sprint 14 operator-a. See docs/operator/sprint-14-pre-deploy-runbook.md
# for full setup procedure + fail-fast contract D-ν validation.

# ATHENA data source toggle (ADR-013 independent from ATLAS):
#   False (default) → StubDataLayer (synthetic seeded OHLCV/IV/skew).
#   True            → SchwabDataLayer via SchwabClient.from_gcp() (real broker).
USE_SCHWAB_DATA_LAYER=False

# ATLAS live portfolio integration flag (ADR-013 D10):
#   False (default) → DB-backed SnapshotBuilder (synthetic, TTL 5s).
#   True            → LiveSnapshotBuilder via SchwabClient.get_positions +
#                     get_balances (TTL 30s).
USE_LIVE_PORTFOLIO=False

# Explicit Schwab account_id for multi-agent subaccount isolation (ADR-013 D9-1).
# REQUIRED if USE_LIVE_PORTFOLIO=True per fail-fast contract D-ν (app refuses
# to start otherwise — see app.py:_build_snapshot_builder). Empty string default
# = SchwabClient auto-discovery picks first account (Eolo behavior preserved
# for synthetic mode).
SCHWAB_ACCOUNT_ID=""

# -----------------------------------------------------------------------------
# Market Data Providers
# -----------------------------------------------------------------------------
POLYGON_API_KEY=
BENZINGA_API_KEY=
FRED_API_KEY=

# -----------------------------------------------------------------------------
# On-chain Data
# -----------------------------------------------------------------------------
GLASSNODE_API_KEY=
CRYPTOQUANT_API_KEY=

# -----------------------------------------------------------------------------
# ATLAS Risk Service
# -----------------------------------------------------------------------------
ATLAS_ENDPOINT=http://localhost:8001
ATLAS_FAIL_OPEN=false   # IMPORTANT: keep `false` (fail closed for safety)

# -----------------------------------------------------------------------------
# Notifications
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
# Comma-separated list of authorized Telegram chat IDs (integers).
# First ID = primary destination for ATLAS alert messages.
# Fail-closed: if empty or unset, ALL bot commands and alerts are denied.
# Example: TELEGRAM_ALLOWED_CHAT_IDS=123456789,987654321
TELEGRAM_ALLOWED_CHAT_IDS=

# -----------------------------------------------------------------------------
# Crypto Exchange Keys (CCXT)
# -----------------------------------------------------------------------------
BINANCE_API_KEY=
BINANCE_API_SECRET=
COINBASE_API_KEY=
COINBASE_API_SECRET=
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO   # DEBUG, INFO, WARNING, ERROR

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
ENVIRONMENT=development   # development, staging, production

# -----------------------------------------------------------------------------
# Multi-Agent System Specific
# -----------------------------------------------------------------------------
# ClaudeRouter config path
CLAUDE_ROUTER_CONFIG=multi-agent-system/claude_router/config/routing_rules.yaml

# Maximum daily LLM cost before alerting (USD)
LLM_DAILY_COST_ALERT=50

# Maximum monthly LLM cost before alerting (USD)
LLM_MONTHLY_COST_ALERT=200

# === TRADING MODE ===
# Default: paper. Always paper unless you explicitly intend real-money trading.
# To activate real mode, set BOTH variables:
#   TRADING_MODE=real
#   TRADING_MODE_CONFIRM=CAUTION_GOING_LIVE_STOPPING_PAPER_GOING_REAL_TRADING
#
# This double-flag pattern prevents accidental real trading.
# In Sprint 4+, SCHWAB_PAPER_TRADING will derive from TRADING_MODE automatically.
TRADING_MODE=paper
# TRADING_MODE_CONFIRM=  # only set when TRADING_MODE=real
